---
version: kuri 1.0
type: indicator
name: Money Flow Index
short: MFI
pane: separate
---

length = param.int(14, title="Length", min=1)

mfiValue = kuri.mfi(hlc3, length)
mark(mfiValue, title="MFI", color=#3B82F6)

mark.level(80, title="Overbought", color=#787B86)
mark.level(50, title="Middle", color=#787B86)
mark.level(20, title="Oversold", color=#787B86)
